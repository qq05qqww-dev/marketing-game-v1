generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
  MERCHANT_ADMIN
  MERCHANT_STAFF
}

enum MemberLevel {
  NORMAL
  VIP
}

enum AuthProvider {
  EMAIL
  GOOGLE
  LINE
  FACEBOOK
}

enum GameType {
  WHEEL
  SCRATCH
  FLIP
  GRID
  GOLDEN_EGG
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ENDED
}

enum RewardStatus {
  UNUSED
  USED
  EXPIRED
}

enum PrizeType {
  WIN
  LOSE
}

enum PrizeStatus {
  ACTIVE
  DISABLED
}

enum SerialCodeStatus {
  UNUSED
  USED
  DISABLED
  EXPIRED
}

enum PlayStatus {
  SUCCESS
  FAILED
}

enum ClaimStatus {
  PENDING
  CLAIMED
  CANCELLED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Tenant {
  id           Int          @id @default(autoincrement())
  name         String
  slug         String       @unique
  contactName  String?
  contactPhone String?
  contactEmail String?
  status       TenantStatus @default(ACTIVE)
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  campaigns       Campaign[]
  gameConfigs     GameConfig[]
  prizes          Prize[]
  rewards         UserReward[]
  serialCodes     SerialCode[]
  playRecords     PlayRecord[]
  rewardRecords   RewardRecord[]
  shareRewardLogs ShareRewardLog[]

  @@index([status])
  @@index([createdAt])
}

model User {
  id          Int         @id @default(autoincrement())
  name        String
  email       String      @unique
  password    String?
  role        UserRole    @default(USER)
  memberLevel MemberLevel @default(NORMAL)

  // V2.3 多商家權限版：
  // tenantId 為空代表平台帳號或一般未歸屬會員。
  // 商家管理員 / 商家員工會綁定指定 Tenant。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  authProvider AuthProvider @default(EMAIL)
  socialId     String?
  avatarUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rewards         UserReward[]
  playRecords     PlayRecord[]
  shareRewardLogs ShareRewardLog[]

  @@index([tenantId])
  @@index([role])
  @@index([authProvider])
  @@index([socialId])
}

model Campaign {
  id          Int            @id @default(autoincrement())
  title       String
  slug        String?        @unique
  description String?
  gameType    GameType
  status      CampaignStatus @default(DRAFT)

  // V2.3 多商家權限版：活動歸屬商家。
  // 先設為可空，方便舊資料庫平滑 migrate。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  startAt DateTime?
  endAt   DateTime?

  dailyLimit    Int?         @default(3)
  totalLimit    Int?         @default(10)
  requireLogin  Boolean      @default(true)
  allowedRole   UserRole?
  requiredLevel MemberLevel?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prizes        Prize[]
  rewards       UserReward[]
  playRecords   PlayRecord[]
  serialCodes   SerialCode[]
  gameConfig    GameConfig?
  rewardRecords RewardRecord[]

  @@index([tenantId])
  @@index([gameType])
  @@index([status])
  @@index([startAt])
  @@index([endAt])
}

model GameConfig {
  id         Int      @id @default(autoincrement())
  campaignId Int      @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // V2.3 多商家權限版：讓前台設定也能依商家隔離查詢。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // 正式上線版遊戲設定集中保存：
  // 例如金蛋顏色、倒數設定、序號區塊樣式、分享設定、底部功能列設定等。
  settings Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Prize {
  id         Int @id @default(autoincrement())
  campaignId Int

  // V2.3 多商家權限版：獎項歸屬商家。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  // 原本欄位保留
  title       String
  remainStock Int    @default(0)
  probability Float

  // 正式版新增欄位
  shortName   String?
  description String?
  imageUrl    String?
  icon        String?
  type        PrizeType   @default(WIN)
  status      PrizeStatus @default(ACTIVE)

  // stockTotal / stockUsed 用於正式庫存管理。
  // remainStock 保留給你目前既有程式相容。
  stockTotal Int @default(0)
  stockUsed  Int @default(0)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  rewards       UserReward[]
  playRecords   PlayRecord[]
  rewardRecords RewardRecord[]

  @@index([tenantId])
  @@index([campaignId])
  @@index([status])
  @@index([type])
}

model UserReward {
  id         Int @id @default(autoincrement())
  userId     Int
  campaignId Int
  prizeId    Int

  // V2.3 多商家權限版：玩家獎勵歸屬商家。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  code      String       @unique
  status    RewardStatus @default(UNUSED)
  createdAt DateTime     @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prize    Prize    @relation(fields: [prizeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SerialCode {
  id         Int      @id @default(autoincrement())
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // V2.3 多商家權限版：序號歸屬商家。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  code String @unique

  // 一組序號可以增加幾次抽獎機會
  rewardChance Int @default(1)

  status SerialCodeStatus @default(UNUSED)

  batchCode String?
  note      String?

  // 發放管理
  distributedAt      DateTime?
  distributedTo      String?
  distributedChannel String?

  // 使用紀錄
  usedAt DateTime?
  usedBy String?

  // 有效期限
  expireAt DateTime?

  playRecords PlayRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([campaignId])
  @@index([status])
  @@index([batchCode])
  @@index([expireAt])
  @@index([distributedAt])
  @@index([usedAt])
}

model PlayRecord {
  id Int @id @default(autoincrement())

  // 原本 userId 是必填。
  // 正式活動可能有免登入玩家，所以改成可選。
  userId Int?

  campaignId Int
  prizeId    Int?

  // V2.3 多商家權限版：遊玩紀錄歸屬商家。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  isWin    Boolean  @default(false)
  playedAt DateTime @default(now())

  // 正式版新增
  gameType GameType   @default(WHEEL)
  status   PlayStatus @default(SUCCESS)

  serialCodeId Int?
  serialCode   SerialCode? @relation(fields: [serialCodeId], references: [id], onDelete: SetNull)

  // 玩家資訊，可支援免登入活動
  playerName  String?
  playerPhone String?
  playerEmail String?
  playerIp    String?
  userAgent   String?

  // 遊戲結果資料：
  // GOLDEN_EGG：可放 eggNumber
  // WHEEL：可放 angle / segment
  // GRID：可放 gridIndex
  resultPayload Json @default("{}")

  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  prize    Prize?   @relation(fields: [prizeId], references: [id], onDelete: SetNull)

  rewardRecord RewardRecord?

  @@index([tenantId])
  @@index([userId])
  @@index([campaignId])
  @@index([gameType])
  @@index([prizeId])
  @@index([serialCodeId])
  @@index([playedAt])
}

model RewardRecord {
  id         Int      @id @default(autoincrement())
  campaignId Int
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // V2.3 多商家權限版：中獎 / 發獎紀錄歸屬商家。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  playRecordId Int        @unique
  playRecord   PlayRecord @relation(fields: [playRecordId], references: [id], onDelete: Cascade)

  prizeId Int?
  prize   Prize? @relation(fields: [prizeId], references: [id], onDelete: SetNull)

  status ClaimStatus @default(PENDING)

  winnerName  String?
  winnerPhone String?
  winnerEmail String?

  claimCode String?   @unique
  claimedAt DateTime?
  claimedBy String?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([campaignId])
  @@index([prizeId])
  @@index([status])
  @@index([createdAt])
}

model ShareRewardLog {
  id         Int  @id @default(autoincrement())
  userId     Int
  campaignId Int?

  // V2.3 多商家權限版：分享獎勵紀錄歸屬商家。
  tenantId Int?
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  gameId      String
  rewardType  String   @default("SHARE")
  rewardCount Int      @default(1)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([gameId])
  @@index([createdAt])
  @@index([userId, gameId, createdAt])
}
